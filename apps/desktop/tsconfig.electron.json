{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "rootDir": ".",
    "outDir": ".electron-build",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": [
      "node",
      "electron"
    ]
  },
  "include": [
    "electron/**/*.ts",
    "lib/electron/contracts.ts",
    "types/**/*.d.ts"
  ]
}
