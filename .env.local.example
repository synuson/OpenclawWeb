# OpenClawWEB 환경 변수 예시
#
# 가장 쉬운 시작 방법:
# 1) npm run setup:web
# 2) apps/web/.env.local 파일 열기
# 3) 필요한 값만 채우기
# 4) npm run dev
#
# 직접 복사하고 싶다면:
# Copy-Item .env.local.example apps/web/.env.local
#
# 선택 사항:
# 루트 .env.local 도 같은 내용으로 만들어 두면 저장소 전체에서 같은 값을 공유하기 편합니다.
# Copy-Item .env.local.example .env.local
#
# 아무 값도 넣지 않으면 데모 모드로 실행됩니다.

# --------------------------------------------------
# 1) 내 OpenClaw 연결
#
# 아래 둘 중 하나로 시작하세요.
#
# 1. 커스텀 API 서버 예시
# OPENCLAW_BASE_URL=https://your-openclaw-host/api
#
# 2. stock OpenClaw gateway 예시
# OPENCLAW_BASE_URL=https://your-openclaw-host
#
# API key가 없으면 비워 둘 수 있습니다.
# --------------------------------------------------
OPENCLAW_BASE_URL=
OPENCLAW_API_KEY=

# Bearer 방식이 아닐 때만 바꾸세요.
OPENCLAW_API_KEY_HEADER=Authorization
OPENCLAW_API_KEY_PREFIX=Bearer 
OPENCLAW_EXTRA_HEADERS_JSON=

# OpenClaw chat / task 경로
# 대부분 기본값 그대로 두면 됩니다.
# /chat 이 없는 stock gateway라면 앱이 /v1/chat/completions, /v1/responses 도 자동 시도합니다.
OPENCLAW_CHAT_PATH=/chat
OPENCLAW_CHAT_COMPLETIONS_PATH=/v1/chat/completions
OPENCLAW_RESPONSES_PATH=/v1/responses
OPENCLAW_TASKS_PATH=/tasks
OPENCLAW_TASK_DETAIL_PATH=/tasks/:id
OPENCLAW_TASK_ARTIFACTS_PATH=/tasks/:id/artifacts
OPENCLAW_MODEL=openai-codex/gpt-5.3-codex
OPENCLAW_MAX_TOKENS=420

# --------------------------------------------------
# 2) direct LLM 사용 또는 OpenClaw 실패 시 폴백
# 하나만 넣어도 됩니다.
# MEETING_LLM_PROVIDER 로 강제 지정하지 않으면
# OpenClaw -> openai -> anthropic -> cerebras -> mock 순으로 선택됩니다.
# --------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

CEREBRAS_API_KEY=
CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507

# 선택: 회의 provider 강제 지정
# 값: openclaw | openai | anthropic | cerebras | mock
MEETING_LLM_PROVIDER=

# --------------------------------------------------
# 3) 음성 기능
# 브라우저 기본 STT/TTS 는 아무 값 없이도 동작할 수 있습니다.
# Whisper 는 OPENAI_API_KEY 가 필요합니다.
# ElevenLabs 는 아래 키가 필요합니다.
# --------------------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
NEXT_PUBLIC_ELEVENLABS_DEFAULT_VOICE_ID=

# --------------------------------------------------
# 4) 시장 데이터
# 미국 실데이터는 Twelve Data 키가 필요합니다.
# 국내 실데이터와 모의투자는 별도 Kiwoom 호환 프록시가 필요합니다.
# --------------------------------------------------
TWELVE_DATA_API_KEY=
KIWOOM_PROXY_BASE_URL=
KIWOOM_PROXY_TOKEN=
KIWOOM_USE_MOCK=true
