# 빠른 체크리스트
# - 프로토타입/데모 모드만 원하면 전부 비워둬도 됩니다.
# - 실제 회의 답변을 원하면 LLM 키를 하나 이상 넣으세요.
# - Whisper STT를 쓰려면 OPENAI_API_KEY가 필요합니다.
# - 미국 시세 실데이터를 쓰려면 TWELVE_DATA_API_KEY가 필요합니다.
# - 국내 시세와 국내 모의투자를 쓰려면 KIWOOM_PROXY_BASE_URL이 필요합니다.
# - 사용자 OpenClaw를 붙이려면 OPENCLAW_BASE_URL이 필요합니다.

# 회의 LLM
# 아래 provider 키 중 하나 이상을 넣으면 실제 회의 답변을 사용합니다.
# 전부 비어 있으면 앱은 로컬 mock 회의 provider로 동작합니다.
CEREBRAS_API_KEY=
CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# 선택: 회의 provider 강제 지정
# 값: cerebras | anthropic | openai | mock
MEETING_LLM_PROVIDER=

# 음성
# 브라우저 STT/TTS는 env가 필요 없습니다.
# Whisper STT는 OPENAI_API_KEY가 필요합니다.
# ElevenLabs TTS는 ELEVENLABS_API_KEY가 필요합니다.
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
NEXT_PUBLIC_ELEVENLABS_DEFAULT_VOICE_ID=

# 미국 시세
# 비워두면 미국 탭은 데모 데이터로 동작합니다.
TWELVE_DATA_API_KEY=

# 국내 시세 + 국내 모의투자
# 사용자 Kiwoom 호환 프록시 주소를 넣으세요.
# 비워두면 국내 탭과 모의투자는 데모 데이터로 동작합니다.
KIWOOM_PROXY_BASE_URL=
KIWOOM_PROXY_TOKEN=

# OpenClaw 연동
# 비워두면 조사 패널은 내장 mock task 엔진으로 동작합니다.
# 아래 기본값은 이 앱의 기본 OpenClaw adapter 계약입니다.
OPENCLAW_BASE_URL=
OPENCLAW_API_KEY=
OPENCLAW_API_KEY_HEADER=Authorization
OPENCLAW_API_KEY_PREFIX=Bearer 
OPENCLAW_TASKS_PATH=/tasks
OPENCLAW_TASK_DETAIL_PATH=/tasks/:id
OPENCLAW_TASK_ARTIFACTS_PATH=/tasks/:id/artifacts
# 선택: 고정 헤더를 JSON으로 넣을 수 있습니다. 예시: {"x-api-key":"demo","x-team":"research"}
OPENCLAW_EXTRA_HEADERS_JSON=
