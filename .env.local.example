# 환경 변수 안내
# - 아무 값도 넣지 않아도 데모 모드로 실행할 수 있습니다.
# - OpenClaw 쪽 GPT/OAuth를 회의 응답에 쓰려면 OPENCLAW_BASE_URL만 먼저 넣어도 됩니다.
# - OpenClaw chat이 실패했을 때 direct LLM으로 폴백하려면 아래 LLM 키를 추가합니다.
# - Whisper STT는 OPENAI_API_KEY가 필요합니다.
# - 미국 시세 실데이터는 TWELVE_DATA_API_KEY가 필요합니다.
# - 국내 시세와 모의투자 실연동은 KIWOOM_PROXY_BASE_URL이 필요합니다.

# 회의 provider
# 우선순위:
# 1) MEETING_LLM_PROVIDER 명시값
# 2) OPENCLAW_BASE_URL이 있으면 openclaw
# 3) openai -> anthropic -> cerebras -> mock
CEREBRAS_API_KEY=
CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# 선택: 회의 provider 강제 지정
# 값: openclaw | openai | anthropic | cerebras | mock
MEETING_LLM_PROVIDER=

# 음성
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
NEXT_PUBLIC_ELEVENLABS_DEFAULT_VOICE_ID=

# 미국 시세
TWELVE_DATA_API_KEY=

# 국내 시세 + 모의투자
KIWOOM_PROXY_BASE_URL=
KIWOOM_PROXY_TOKEN=

# OpenClaw 원격 연결
OPENCLAW_BASE_URL=
OPENCLAW_API_KEY=
OPENCLAW_API_KEY_HEADER=Authorization
OPENCLAW_API_KEY_PREFIX=Bearer 
OPENCLAW_EXTRA_HEADERS_JSON=

# OpenClaw 회의 chat 경로
OPENCLAW_CHAT_PATH=/chat

# OpenClaw 조사 task 경로
OPENCLAW_TASKS_PATH=/tasks
OPENCLAW_TASK_DETAIL_PATH=/tasks/:id
OPENCLAW_TASK_ARTIFACTS_PATH=/tasks/:id/artifacts